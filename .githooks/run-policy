#!/bin/sh

set -eu

HOOK_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

run_powershell() {
    script_path="$HOOK_DIR/validate-policy.ps1"
    if command -v cygpath >/dev/null 2>&1; then
        script_path="$(cygpath -w "$script_path")"
    fi

    if command -v pwsh >/dev/null 2>&1; then
        exec pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$script_path" "$@"
    fi

    if command -v powershell.exe >/dev/null 2>&1; then
        exec powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$script_path" "$@"
    fi

    return 1
}

case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*)
        if run_powershell "$@"; then
            exit 0
        fi
        ;;
esac

exec "$HOOK_DIR/validate-policy.sh" "$@"
